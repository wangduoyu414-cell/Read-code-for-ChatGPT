  "$defs": {
    "repository_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "repo_path",
        "snapshot_id"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "repo_path": {
          "type": "string",
          "minLength": 1
        },
        "snapshot_id": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "line_range": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "start",
        "end"
      ],
      "properties": {
        "start": {
          "type": "integer",
          "minimum": 1
        },
        "end": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "search_hit": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "line_range",
        "snippet",
        "score",
        "snapshot_id",
        "truncated"
      ],
      "properties": {
        "path": {
          "type": "string"
        },
        "line_range": {
          "$ref": "#/$defs/line_range"
        },
        "snippet": {
          "type": "string"
        },
        "score": {
          "type": "number"
        },
        "symbol": {
          "type": "string"
        },
        "snapshot_id": {
          "type": "string"
        },
        "truncated": {
          "type": "boolean"
        }
      }
    },
    "tree_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "type"
      ],
      "properties": {
        "path": {
          "type": "string"
        },
        "type": {
          "type": "string",
          "enum": [
            "file",
            "directory"
          ]
        },
        "language": {
          "type": "string"
        },
        "truncated": {
          "type": "boolean"
        }
      }
    },
    "symbol_hit": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "kind",
        "path",
        "line",
        "confidence"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "kind": {
          "type": "string"
        },
        "path": {
          "type": "string"
        },
        "line": {
          "type": "integer",
          "minimum": 1
        },
        "signature": {
          "type": "string"
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    },
    "tool_error": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "isError",
        "error_code",
        "message",
        "repo_path",
        "snapshot_id",
        "policy_version",
        "audit_id",
        "retryable"
      ],
      "properties": {
        "isError": {
          "type": "boolean",
          "const": true
        },
        "error_code": {
          "type": "string"
        },
        "message": {
          "type": "string"
        },
        "repo_path": {
          "type": "string"
        },
        "snapshot_id": {
          "type": "string"
        },
        "policy_version": {
          "type": "string"
        },
        "audit_id": {
          "type": "string"
        },
        "retryable": {
          "type": "boolean"
        }
      }
    },
    "index_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "files_indexed",
        "files_skipped",
        "duration_ms"
      ],
      "properties": {
        "files_indexed": {
          "type": "integer",
          "minimum": 0
        },
        "files_skipped": {
          "type": "integer",
          "minimum": 0
        },
        "duration_ms": {
          "type": "integer",
          "minimum": 0
        }
      }
    }
  }
