{
  "schema_version": "2026-06-21-design-v2",
  "tools": [
    {
      "name": "repo.list",
      "title": "Repository List",
      "description": "List configured repository names and exact repository paths.",
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false,
        "openWorldHint": false
      },
      "inputSchema": {
        "type": "object",
        "additionalProperties": false,
        "required": [],
        "properties": {}
      },
      "outputSchema": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "repositories",
          "count",
          "policy_version",
          "content_origin",
          "instruction_trust",
          "audit_id",
          "isError",
          "next_cursor",
          "error_code",
          "message",
          "retryable"
        ],
        "properties": {
          "repositories": {
            "type": "array",
            "items": {
              "$ref": "#/$defs/repository_entry"
            }
          },
          "count": {
            "type": "integer",
            "minimum": 0
          },
          "policy_version": {
            "type": "string"
          },
          "content_origin": {
            "type": "string",
            "enum": [
              "repository_snapshot"
            ]
          },
          "instruction_trust": {
            "type": "string",
            "enum": [
              "untrusted"
            ]
          },
          "audit_id": {
            "type": "string",
            "minLength": 1
          },
          "isError": {
            "type": "boolean",
            "default": false
          },
          "error_code": {
            "type": [
              "string",
              "null"
            ]
          },
          "message": {
            "type": [
              "string",
              "null"
            ]
          },
          "next_cursor": {
            "type": [
              "string",
              "null"
            ]
          },
          "retryable": {
            "type": "boolean",
            "default": false
          }
        }
      }
    },
    {
      "name": "repo.search",
      "title": "Repository Search",
      "description": "Search within an authorized immutable repository snapshot and return bounded code hits with provenance.",
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false,
        "openWorldHint": false
      },
      "inputSchema": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "repo_path",
          "query"
        ],
        "properties": {
          "repo_path": {
            "type": "string",
            "minLength": 1
          },
          "snapshot_id": {
            "type": "string",
            "minLength": 1
          },
          "query": {
            "type": "string",
            "minLength": 1,
            "maxLength": 512
          },
          "mode": {
            "type": "string",
            "enum": [
              "text",
              "symbol",
              "hybrid"
            ],
            "default": "text"
          },
          "limit": {
            "type": "integer",
            "minimum": 1,
            "maximum": 20,
            "default": 10
          }
        }
      },
      "outputSchema": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "repo_path",
          "snapshot_id",
          "policy_version",
          "hits",
          "content_origin",
          "instruction_trust",
          "audit_id",
          "isError",
          "next_cursor",
          "error_code",
          "message",
          "retryable"
        ],
        "properties": {
          "repo_path": {
            "type": "string"
          },
          "snapshot_id": {
            "type": "string"
          },
          "policy_version": {
            "type": "string"
          },
          "hits": {
            "type": "array",
            "items": {
              "$ref": "#/$defs/search_hit"
            }
          },
          "truncated": {
            "type": "boolean"
          },
          "content_origin": {
            "type": "string",
            "enum": [
              "repository_snapshot"
            ]
          },
          "instruction_trust": {
            "type": "string",
            "enum": [
              "untrusted"
            ]
          },
          "audit_id": {
            "type": "string",
            "minLength": 1
          },
          "isError": {
            "type": "boolean",
            "default": false
          },
          "error_code": {
            "type": [
              "string",
              "null"
            ]
          },
          "message": {
            "type": [
              "string",
              "null"
            ]
          },
          "next_cursor": {
            "type": [
              "string",
              "null"
            ]
          },
          "retryable": {
            "type": "boolean",
            "default": false
          }
        }
      }
    },
